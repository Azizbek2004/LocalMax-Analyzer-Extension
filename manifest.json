{
    "manifest_version": 3,
    "name": "LocalMax Analyzer",
    "version": "1.0.0",
    "description": "One-click offline chess analysis with AI coaching. Works on Chess.com and Lichess. 100% private, no accounts, no limits.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png"
        }
    },
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.chess.com/*"
            ],
            "js": [
                "content-scripts/chesscom.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.lichess.org/*"
            ],
            "js": [
                "content-scripts/lichess.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "activeTab"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "stockfish/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
}